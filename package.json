{
	"name": "crm-vue-supabase",
	"version": "2.2.0",
	"private": true,
	"description": "CRM System based on Vue 3 with Supabase SDK",
	"author": "igorexa34314",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/igorexa34314/crm-vue-supabase.git"
	},
	"scripts": {
		"dev": "vite",
		"build": "run-p typecheck \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "vite build",
		"analyze": "analyze",
		"typecheck": "vue-tsc --build",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --fix --cache",
		"format": "prettier --write --cache src/",
		"supabase:types": "supabase gen types --lang=typescript --project-id sxjleofipivdmluufxic > ./src/types/database-generated.ts",
		"postinstall": "simple-git-hooks"
	},
	"dependencies": {
		"@pinia/colada": "^1.3.0",
		"@supabase/supabase-js": "^2.105.4",
		"@unhead/vue": "^3.1.0",
		"@vueuse/core": "^14.3.0",
		"@vueuse/router": "^14.3.0",
		"chart.js": "^4.5.1",
		"deep-equal": "^2.2.3",
		"klona": "^2.0.6",
		"pinia": "^4.0.0",
		"randomcolor": "^0.6.2",
		"ufo": "^1.6.4",
		"uuid": "^14.0.0",
		"vue": "^3.5.34",
		"vue-chartjs": "^5.3.3",
		"vue-i18n": "^11.4.4",
		"vue-router": "^5.0.7",
		"vuetify": "^4.0.7",
		"vuetify-birthdaypicker": "^0.1.0"
	},
	"devDependencies": {
		"@fontsource/roboto": "^5.3.0",
		"@iconify-json/mdi": "^1.2.3",
		"@intlify/unplugin-vue-i18n": "^11.2.4",
		"@pinia/colada-devtools": "^1.1.1",
		"@tsconfig/node24": "^24.0.4",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@types/deep-equal": "^1.0.4",
		"@types/node": "^24.13.3",
		"@types/randomcolor": "^0.5.9",
		"@unocss/eslint-config": "^66.7.5",
		"@unocss/preset-icons": "^66.7.5",
		"@unocss/preset-wind4": "^66.7.5",
		"@vitejs/plugin-vue": "^6.0.8",
		"@vue/eslint-config-typescript": "^14.9.0",
		"@vue/tsconfig": "^0.9.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.10.0",
		"jiti": "^2.7.0",
		"nano-staged": "^1.0.2",
		"npm-run-all2": "^9.0.2",
		"prettier": "^3.9.6",
		"sass-embedded": "^1.100.0",
		"simple-git-hooks": "^2.13.1",
		"supabase": "^2.109.1",
		"type-fest": "^5.8.0",
		"typescript": "^6.0.3",
		"unocss": "^66.7.5",
		"unocss-preset-vuetify": "^0.3.0",
		"unplugin-fonts": "^2.0.0",
		"vite": "^8.1.5",
		"vite-bundle-analyzer": "^1.3.9",
		"vite-plugin-vue-devtools": "^8.1.5",
		"vite-plugin-vuetify": "^2.1.3",
		"vue-tsc": "^3.3.7"
	},
	"packageManager": "pnpm@11.15.1",
	"simple-git-hooks": {
		"pre-commit": "./node_modules/.bin/nano-staged"
	},
	"nano-staged": {
		"*": "eslint --fix"
	}
}
