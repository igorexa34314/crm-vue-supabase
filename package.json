{
	"name": "crm-vue-supabase",
	"version": "2.2.0",
	"private": true,
	"description": "CRM System based on Vue 3 with Supabase SDK",
	"author": "igorexa34314",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/igorexa34314/crm-vue-supabase.git"
	},
	"scripts": {
		"dev": "vite",
		"build": "run-p typecheck \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "vite build",
		"analyze": "analyze",
		"typecheck": "vue-tsc --build",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --fix --cache",
		"format": "prettier --write --cache src/",
		"supabase:types": "supabase gen types --lang=typescript --project-id sxjleofipivdmluufxic > ./src/types/database-generated.ts"
	},
	"dependencies": {
		"@mdi/js": "^7.4.47",
		"@pinia/colada": "^1.0.0",
		"@supabase/supabase-js": "^2.100.0",
		"@unhead/vue": "^2.1.12",
		"@vueuse/core": "^14.2.1",
		"@vueuse/router": "^14.2.1",
		"chart.js": "^4.5.1",
		"deep-equal": "^2.2.3",
		"klona": "^2.0.6",
		"pinia": "^3.0.4",
		"randomcolor": "^0.6.2",
		"ufo": "^1.6.3",
		"uuid": "^13.0.0",
		"vue": "^3.5.30",
		"vue-chartjs": "^5.3.3",
		"vue-i18n": "^11.3.0",
		"vue-router": "^5.0.4",
		"vuetify": "^4.0.3",
		"vuetify-birthdaypicker": "^0.1.0"
	},
	"devDependencies": {
		"@intlify/unplugin-vue-i18n": "^11.0.7",
		"@pinia/colada-devtools": "^0.4.5",
		"@tsconfig/node24": "^24.0.4",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@types/deep-equal": "^1.0.4",
		"@types/node": "^24.12.0",
		"@types/randomcolor": "^0.5.9",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/tsconfig": "^0.9.0",
		"eslint": "^10.1.0",
		"eslint-plugin-vue": "^10.8.0",
		"jiti": "^2.6.1",
		"lint-staged": "^16.4.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"sass-embedded": "^1.98.0",
		"simple-git-hooks": "^2.13.1",
		"supabase": "^2.83.0",
		"type-fest": "^5.5.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vite-bundle-analyzer": "^1.3.6",
		"vite-plugin-vue-devtools": "^8.1.0",
		"vite-plugin-vuetify": "^2.1.3",
		"vue-tsc": "^3.2.6"
	},
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"esbuild",
			"simple-git-hooks",
			"supabase"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
